{
  "name": "@warrenbuckley/audio-visualizer",
  "version": "1.0.0",
  "description": "A Lit WebComponent that visualises real-time microphone frequency bands as animated bars. Ported from the LiveKit AgentAudioVisualizerBar React component.",
  "keywords": [
    "web-component",
    "web-components",
    "custom-element",
    "custom-elements",
    "audio",
    "visualizer",
    "microphone",
    "waveform",
    "frequency",
    "lit",
    "lit-element"
  ],
  "author": "Warren Buckley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/warrenbuckley/audio-visualizer.git"
  },
  "homepage": "https://warrenbuckley.github.io/audio-visualizer",
  "bugs": {
    "url": "https://github.com/warrenbuckley/audio-visualizer/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/audio-visualizer.js",
      "types": "./dist/audio-visualizer.d.ts"
    },
    "./standalone": {
      "import": "./dist/audio-visualizer.standalone.js"
    }
  },
  "files": [
    "dist",
    "custom-elements.json",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run build:lib && npm run build:standalone && npm run build:cem",
    "build:demo": "tsc && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:standalone": "vite build --config vite.standalone.config.ts",
    "build:cem": "cem analyze --globs \"src/audio-analyzer.ts\" \"src/audio-visualizer.ts\" \"src/index.ts\" --litelement",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "lit": "^3.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.4"
  },
  "customElements": "custom-elements.json"
}
